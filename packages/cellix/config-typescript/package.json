{
	"name": "@cellix/config-typescript",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Reimplemented TypeScript config patterns (inspired by cellixjs, modernized for Node 24 + no graphql). Extension point.",
	"main": "tsconfig.base.json",
	"files": [
		"tsconfig.base.json"
	],
	"scripts": {
		"build": "mkdir -p dist && touch dist/.gitkeep",
		"lint": "biome lint package.json tsconfig.base.json",
		"format": "biome format --write package.json tsconfig.base.json",
		"format:check": "biome format package.json tsconfig.base.json"
	}
}
