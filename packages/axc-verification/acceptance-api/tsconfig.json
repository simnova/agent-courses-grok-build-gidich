{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"rootDir": ".",
		"types": ["node", "@cucumber/cucumber"]
	},
	"include": ["src", "cucumber.js"],
	"exclude": ["node_modules", "dist", "target", "reports"]
}
