{
	"name": "@axc-verification/acceptance-api",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "tsc --build",
		"test:acceptance": "cucumber-js --config cucumber.js src/features/**/*.feature --require src/step-definitions/**/*.steps.ts --require src/world.ts --require-module tsx --format @serenity-js/cucumber",
		"test": "cucumber-js",
		"report": "serenity-bdd run --source target/site/serenity --destination target/site/serenity",
		"test:acceptance:report": "pnpm run test:acceptance && pnpm run report",
		"clean": "rimraf target reports dist",
		"lint": "biome lint",
		"format": "biome format --write",
		"format:check": "biome format ."
	},
	"dependencies": {
		"@apps/api": "workspace:*",
		"@axc/axc": "workspace:*",
		"@cucumber/cucumber": "catalog:",
		"@serenity-js/assertions": "catalog:",
		"@serenity-js/console-reporter": "catalog:",
		"@serenity-js/core": "catalog:",
		"@serenity-js/cucumber": "catalog:",
		"@serenity-js/serenity-bdd": "catalog:",
		"hono": "catalog:"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"rimraf": "^6.0.1",
		"tsx": "catalog:",
		"typescript": "catalog:"
	}
}
