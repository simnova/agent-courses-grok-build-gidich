{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"workspaces": {
		".": {
			"entry": ["portless.config.cjs"],
			"project": ["*.js"]
		},
		"apps/api": {
			"entry": ["src/index.ts"],
			"project": ["src/**/*.ts", "rolldown.config.ts", "host.json"],
			"ignore": ["rolldown.config.ts", "src/service-config/**"],
			"ignoreDependencies": ["@vitest/coverage-istanbul", "archunit", "@axc/domain", "mongodb", "mongoose", "mongodb-memory-server-core"]
		},
		"apps/docs": {
			"entry": ["src/pages/index.tsx", "docusaurus.config.ts", "sidebars.ts"],
			"project": ["src/**/*.{ts,tsx}", "docusaurus.config.ts", "sidebars.ts"],
			"ignoreDependencies": ["clsx", "@docusaurus/plugin-content-docs"]
		},
		"packages/axc": {
			"entry": ["src/index.ts"],
			"project": ["src/index.ts", "src/rest/**/*.ts", "src/domain/**/*.ts"],
			"ignore": ["src/application-services/**", "src/persistence/**", "src/service-mongoose/**"],
			"ignoreDependencies": ["mongoose"]
		},
		"packages/domain": {
			"entry": ["src/index.ts"],
			"project": ["src/index.ts"]
		},
		"packages/axc-verification/archunit-tests": {
			"entry": ["src/index.ts"],
			"project": ["src/index.ts", "src/architecture.test.ts"]
		},
		"packages/axc-verification/acceptance-api": {
			"entry": ["src/world.ts", "src/step-definitions/healthcheck.steps.ts"],
			"project": ["src/**/*.ts"],
			"ignoreBinaries": [],
			"ignoreDependencies": ["@axc/axc", "hono"]
		},
		"packages/cellix/*": {
			"project": ["src/**/*.ts"]
		}
	},
	"ignoreWorkspaces": ["packages/cellix/config-typescript"],
	"ignore": [
		"**/dist/**",
		"**/coverage/**",
		"**/__tests__/**",
		"**/*.test.ts",
		"**/*.spec.ts",
		"**/.turbo/**",
		".agents/**",
		".github/**",
		"portless.config.cjs",
		"**/reports/**",
		"target/**"
	],
	"ignoreDependencies": [
		"@types/*",
		"@serenity-js/*",
		"@cucumber/*",
		"@vitest/coverage-istanbul",
		"archunit",
		"lint-staged",
		"rolldown",
		"vitest",
		"tsx"
	],
	"ignoreBinaries": ["func", "snyk"]
}
