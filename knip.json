{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"workspaces": {
		".": {
			"entry": ["portless.config.cjs", "scripts/capture-evidence.mjs", "scripts/gates/*.mjs"]
		},
		"apps/api": {
			"project": ["src/**/*.ts", "rolldown.config.ts", "host.json"],
			"ignore": ["rolldown.config.ts"],
			"ignoreDependencies": ["@vitest/coverage-istanbul", "archunit", "mongodb-memory-server-core"]
		},
		"apps/docs": {
			"project": ["src/**/*.{ts,tsx}"],
			"ignoreDependencies": ["clsx", "@docusaurus/plugin-content-docs"]
		},
		"packages/axc": {
			"project": ["src/**/*.ts"],
			"ignore": ["src/persistence/index.ts", "src/service-mongoose/index.ts", "src/application-services/index.ts"],
			"ignoreDependencies": ["mongoose"]
		},
		"packages/domain": {
			"project": ["src/**/*.ts"]
		},
		"packages/axc-verification/archunit-tests": {
			"project": ["src/**/*.ts"]
		},
		"packages/axc-verification/acceptance-api": {
			"entry": ["src/world.ts", "src/step-definitions/healthcheck.steps.ts"],
			"project": ["src/**/*.ts"],
			"ignoreBinaries": [],
			"ignoreDependencies": [
				"@serenity-js/console-reporter",
				"@serenity-js/cucumber",
				"@serenity-js/serenity-bdd",
				"hono",
				"@axc/axc"
			]
		},
		"packages/cellix/*": {
			"project": ["src/**/*.ts"]
		},
		"packages/cellix/config-typescript": {
			"project": ["tsconfig.base.json", "package.json"]
		}
	},
	"ignore": [],
	"ignoreDependencies": ["lint-staged", "rolldown", "tsx", "snyk", "@vitest/coverage-istanbul", "vitest"],
	"ignoreBinaries": []
}
