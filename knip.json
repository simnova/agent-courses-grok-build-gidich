{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"workspaces": {
		".": {
			"entry": ["portless.config.cjs"],
			"project": ["*.js"]
		},
		"apps/api": {
			"entry": ["src/index.ts", "src/**/*.ts", "rolldown.config.ts"],
			"project": ["src/**/*.ts", "*.mjs", "host.json"],
			"ignoreDependencies": []
		},
		"apps/docs": {
			"entry": ["src/pages/index.tsx", "docusaurus.config.ts", "sidebars.ts"],
			"project": ["src/**/*.{ts,tsx}", "*.ts", "*.js"]
		},
		"packages/axc": {
			"entry": ["src/index.ts"],
			"project": ["src/**/*.ts"]
		},
		"packages/domain": {
			"entry": ["src/index.ts"],
			"project": ["src/**/*.ts"]
		},
		"packages/axc-verification/archunit-tests": {
			"entry": ["src/index.ts", "src/architecture.test.ts"],
			"project": ["src/**/*.ts"]
		},
		"packages/axc-verification/acceptance-api": {
			"entry": ["cucumber.js", "src/world.ts", "src/step-definitions/healthcheck.steps.ts"],
			"project": ["src/**/*.ts"],
			"ignoreBinaries": []
		},
		"packages/cellix/*": {
			"project": ["src/**/*.ts"]
		}
	},
	"ignoreWorkspaces": ["packages/cellix/config-typescript"],
	"ignore": [
		"**/dist/**",
		"**/coverage/**",
		"**/__tests__/**",
		"**/*.test.ts",
		"**/*.spec.ts",
		"**/.turbo/**",
		".agents/**",
		".github/**",
		"portless.config.cjs",
		"**/reports/**",
		"target/**"
	],
	"ignoreDependencies": [
		"@types/*",
		"@serenity-js/*",
		"@cucumber/*"
	],
	"ignoreBinaries": ["func", "snyk"]
}
