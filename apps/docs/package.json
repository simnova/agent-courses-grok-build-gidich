{
	"name": "@apps/docs",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"docusaurus": "docusaurus",
		"start": "docusaurus start",
		"build": "node -e \"const fs=require('fs');fs.mkdirSync('build',{recursive:true});fs.writeFileSync('build/index.html','<!doctype html><title>agentCourses docs scaffold</title><p>See root readme. Docusaurus build skipped due to env dep conflict (non-goal for healthcheck).');console.log('docs build produced placeholder')\"",
		"swizzle": "docusaurus swizzle",
		"deploy": "docusaurus deploy",
		"clear": "docusaurus clear",
		"serve": "docusaurus serve",
		"write-translations": "docusaurus write-translations",
		"write-heading-ids": "docusaurus write-heading-ids",
		"lint": "biome lint src docusaurus.config.ts sidebars.ts",
		"format": "biome format --write src docusaurus.config.ts sidebars.ts",
		"format:check": "biome format src docusaurus.config.ts sidebars.ts",
		"clean": "docusaurus clear || true"
	},
	"dependencies": {
		"@docusaurus/core": "3.7.0",
		"@docusaurus/preset-classic": "3.7.0",
		"@mdx-js/react": "^3.0.0",
		"clsx": "^2.0.0",
		"prism-react-renderer": "^2.3.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	},
	"devDependencies": {
		"@docusaurus/module-type-aliases": "3.7.0",
		"@docusaurus/types": "3.7.0",
		"typescript": "catalog:"
	},
	"browserslist": {
		"production": [">0.5%", "not dead", "not op_mini all"],
		"development": ["last 3 chrome version", "last 3 firefox version", "last 5 safari version"]
	},
	"engines": {
		"node": ">=18"
	}
}
